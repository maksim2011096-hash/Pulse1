    colorLabel.TextColor3 = Color3.fromRGB(200, 200, 255)
    colorLabel.Font = Enum.Font.GothamBold
    colorLabel.TextSize = 14
    colorLabel.Parent = espContainer
    
    yOffset = yOffset + 30
    
    local colorModes = {
        {"Радуга", "Rainbow"},
        {"Галактика", "Galaxy"},
        {"Неон", "Neon"},
        {"Кислотный", "Acid"},
        {"Белый пульс", "WhitePulse"},
        {"Синий пульс", "BluePulse"},
    }
    
    for i, modeData in ipairs(colorModes) do
        local btn = Instance.new("TextButton")
        local col = (i-1) % 3
        local row = math.floor((i-1) / 3)
        local xPos = 0.05 + col * 0.32
        local yPos = yOffset + row * 28
        btn.Size = UDim2.new(0.30, 0, 0, 24)
        btn.Position = UDim2.new(xPos, 0, 0, yPos)
        btn.BackgroundColor3 = Color3.fromRGB(120, 70, 190)
        btn.Text = modeData[1]
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.TextSize = 11
        btn.Font = Enum.Font.Gotham
        btn.Parent = espContainer
        
        local grad = Instance.new("UIGradient")
        grad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(140, 90, 220)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 140, 255))
        })
        grad.Rotation = 45
        grad.Parent = btn
        
        local btnCorner = Instance.new("UICorner")
        btnCorner.CornerRadius = UDim.new(0, 6)
        btnCorner.Parent = btn
        
        if modeData[2] == ESP.ColorMode then
            btn.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
        end
        table.insert(espColorButtons, btn)
        
        btn.MouseButton1Click:Connect(function()
            ESP.ColorMode = modeData[2]
            for _, b in pairs(espColorButtons) do
                b.BackgroundColor3 = Color3.fromRGB(120, 70, 190)
            end
            btn.BackgroundColor3 = Color3.fromRGB(0, 200, 255)
            UpdateESPColors()
        end)
    end
    
    local totalRows = math.ceil(#colorModes / 3)
    local containerHeight = yOffset + totalRows * 28 + 30
    espContainer.Size = UDim2.new(1, 0, 0, containerHeight)
    
    espToggleBtn.MouseButton1Click:Connect(function()
        ESP.Enabled = not ESP.Enabled
        if ESP.Enabled then
            espStatusLabel.Text = "✅ ESP ВКЛЮЧЕН"
            espStatusLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
            espToggleBtn.Text = "❌ ВЫКЛЮЧИТЬ"
            espToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            RefreshESP()
        else
            espStatusLabel.Text = "❌ ESP ОТКЛЮЧЕН"
            espStatusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
            espToggleBtn.Text = "🔮 ВКЛЮЧИТЬ"
            espToggleBtn.BackgroundColor3 = Color3.fromRGB(140, 80, 220)
            UpdateESPState()
        end
    end)
    
    toggleVisibilityBtn.MouseButton1Click:Connect(function()
        espVisible = not espVisible
        if espVisible then
            toggleVisibilityBtn.Text = "▲"
            espContainer.Size = UDim2.new(1, 0, 0, containerHeight)
            espContainer.Visible = true
        else
            toggleVisibilityBtn.Text = "▼"
            espContainer.Size = UDim2.new(1, 0, 0, 0)
            espContainer.Visible = false
        end
    end)
    
    task.wait(0.5)
    RefreshESP()
end

