local settingsBindBtn = nil

local function CreateSettingsContent()
    for _, child in ipairs(settingsContent:GetChildren()) do
        child:Destroy()
    end
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 35)
    label.Position = UDim2.new(0, 0, 0, 5)
    label.BackgroundTransparency = 1
    label.Text = "⚙️ Настройки"
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 18
    label.Parent = settingsContent
    
    local bindLabel = Instance.new("TextLabel")
    bindLabel.Size = UDim2.new(1, 0, 0, 25)
    bindLabel.Position = UDim2.new(0, 0, 0, 45)
    bindLabel.BackgroundTransparency = 1
    bindLabel.Text = "Клавиша открытия меню:"
    bindLabel.TextColor3 = Color3.fromRGB(200, 200, 255)
    bindLabel.Font = Enum.Font.Gotham
    bindLabel.TextSize = 14
    bindLabel.Parent = settingsContent
    
    settingsBindBtn = Instance.new("TextButton")
    settingsBindBtn.Size = UDim2.new(0.6, 0, 0, 40)
    settingsBindBtn.Position = UDim2.new(0.2, 0, 0, 75)
    settingsBindBtn.BackgroundColor3 = Color3.fromRGB(60, 30, 100)
    settingsBindBtn.BackgroundTransparency = 0.2
    settingsBindBtn.BorderSizePixel = 1
    settingsBindBtn.BorderColor3 = Color3.fromRGB(200, 100, 255)
    settingsBindBtn.Text = "Текущий: " .. Settings.OpenKey.Name
    settingsBindBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    settingsBindBtn.Font = Enum.Font.GothamBold
    settingsBindBtn.TextSize = 16
    settingsBindBtn.Parent = settingsContent
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 10)
    btnCorner.Parent = settingsBindBtn
    
    local waitingForBind = false
    
    settingsBindBtn.MouseButton1Click:Connect(function()
        waitingForBind = true
        settingsBindBtn.Text = "Нажми клавишу..."
        settingsBindBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        settingsBindBtn.BorderColor3 = Color3.fromRGB(255, 100, 100)
    end)
    
    -- Обработчик ввода для смены бинда
    local bindConnection
    bindConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if not waitingForBind then return end
        if gameProcessed then return end
        
        -- Проверяем, что это клавиша (не мышь и не touch)
        if input.UserInputType == Enum.UserInputType.Keyboard then
            local key = input.KeyCode
            if key ~= Enum.KeyCode.Unknown then
                waitingForBind = false
                Settings.OpenKey = key
                settingsBindBtn.Text = "Текущий: " .. key.Name
                settingsBindBtn.BackgroundColor3 = Color3.fromRGB(60, 30, 100)
                settingsBindBtn.BorderColor3 = Color3.fromRGB(200, 100, 255)
                updateHint()
                -- Отключаем старую привязку, создаем новую (уже есть в основном цикле)
                -- Но основная привязка уже использует Settings.OpenKey, так что все ок
                bindConnection:Disconnect()
                print("🔄 Бинд изменен на: " .. key.Name)
            end
        end
    end)
    
    settingsContent.CanvasSize = UDim2.new(0, 0, 0, 130)
end

-- === ПЕРЕКЛЮЧЕНИЕ ВКЛАДОК ===
local function switchTab(tab)
    universalContent.Visible = false
    tsbContent.Visible = false
    settingsContent.Visible = false
    
    tabUniversal.BackgroundColor3 = Color3.fromRGB(150, 50, 255)
    tabUniversal.BorderColor3 = Color3.fromRGB(150, 50, 255)
    tabTSB.BackgroundColor3 = Color3.fromRGB(150, 50, 255)
    tabTSB.BorderColor3 = Color3.fromRGB(150, 50, 255)
    tabSettings.BackgroundColor3 = Color3.fromRGB(150, 50, 255)
    tabSettings.BorderColor3 = Color3.fromRGB(150, 50, 255)
    
    if tab == "Universal" then
        universalContent.Visible = true
        tabUniversal.BackgroundColor3 = Color3.fromRGB(200, 100, 255)
        tabUniversal.BorderColor3 = Color3.fromRGB(200, 100, 255)
    elseif tab == "TSB" then
        tsbContent.Visible = true
        tabTSB.BackgroundColor3 = Color3.fromRGB(200, 100, 255)
        tabTSB.BorderColor3 = Color3.fromRGB(200, 100, 255)
        if #tsbContent:GetChildren() == 0 then
            CreateTSBContent()
        end
    elseif tab == "Settings" then
        settingsContent.Visible = true
        tabSettings.BackgroundColor3 = Color3.fromRGB(200, 100, 255)
        tabSettings.BorderColor3 = Color3.fromRGB(200, 100, 255)
        if #settingsContent:GetChildren() == 0 then
            CreateSettingsContent()
        end
    end
end

tabUniversal.MouseButton1Click:Connect(function() switchTab("Universal") end)
tabTSB.MouseButton1Click:Connect(function() switchTab("TSB") end)
tabSettings.MouseButton1Click:Connect(function() switchTab("Settings") end)

