local ESP = {
    Enabled = false,
    ColorMode = "Rainbow",
    Data = {},
    ShowName = true,
    ShowKills = true,
    ShowHighlight = true,
}

local function GetESPColor(time)
    local mode = ESP.ColorMode
    if mode == "Rainbow" then
        local hue = (time * 0.2) % 1
        return Color3.fromHSV(hue, 1, 1)
    elseif mode == "Galaxy" then
        local r = 0.5 + 0.5 * math.sin(time * 0.5)
        local g = 0.3 + 0.4 * math.sin(time * 0.7 + 1)
        local b = 0.8 + 0.2 * math.sin(time * 0.9 + 2)
        return Color3.new(r, g, b)
    elseif mode == "Neon" then
        local hue = (time * 0.15) % 1
        return Color3.fromHSV(hue, 1, 0.8)
    elseif mode == "Acid" then
        local r = 0.8 + 0.2 * math.sin(time * 0.8)
        local g = 0.9 + 0.1 * math.sin(time * 0.6 + 1)
        local b = 0.2 + 0.3 * math.sin(time * 0.5 + 2)
        return Color3.new(r, g, b)
    elseif mode == "WhitePulse" then
        local pulse = (math.sin(time * 2) + 1) / 2
        return Color3.new(0.5 + pulse * 0.5, 0.5 + pulse * 0.5, 0.5 + pulse * 0.5)
    elseif mode == "BluePulse" then
        local pulse = (math.sin(time * 2) + 1) / 2
        return Color3.new(0.3 + pulse * 0.4, 0.6 + pulse * 0.3, 0.9 + pulse * 0.1)
    else
        return Color3.fromRGB(255, 255, 255)
    end
end

local function GetTotalKills(p)
    if not ESP.ShowKills then return "" end
    local ls = p:FindFirstChild("leaderstats")
    if ls then
        local kills = ls:FindFirstChild("TotalKills") or ls:FindFirstChild("Total Kills") or ls:FindFirstChild("Kills") or ls:FindFirstChild("Points") or ls:FindFirstChild("Score")
        if kills then
            local val = tonumber(kills.Value)
            if val and val > 0 then return " 💀 " .. tostring(val) end
        end
    end
    return ""
end

local function GetDisplayName(p)
    if not ESP.ShowName then return "" end
    return (p.DisplayName and p.DisplayName ~= "") and p.DisplayName or p.Name
end

local function CreateESPForPlayer(p)
    if p == LocalPlayer then return end
    if ESP.Data[p] then return end

    local char = p.Character
    if not char then return end

    local highlight = Instance.new("Highlight")
    highlight.Parent = char
    highlight.FillColor = Color3.fromRGB(255, 0, 255)
    highlight.FillTransparency = 0.7
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.OutlineTransparency = 0.2
    highlight.Enabled = false

    local billboard = Instance.new("BillboardGui")
    billboard.Parent = char
    local head = char:FindFirstChild("Head") or char:FindFirstChild("Torso") or char:FindFirstChild("HumanoidRootPart")
    if not head then
        local parts = char:GetChildren()
        for _, part in pairs(parts) do
            if part:IsA("BasePart") then
                head = part
                break
            end
        end
    end
    billboard.Adornee = head
    billboard.Size = UDim2.new(0, 400, 0, 30)
    billboard.StudsOffset = Vector3.new(0, 2.5, 0)
    billboard.AlwaysOnTop = true
    billboard.Enabled = false

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = GetDisplayName(p) .. GetTotalKills(p)
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextSize = 18
    label.Font = Enum.Font.GothamBold
    label.TextStrokeTransparency = 0.2
    label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    label.Parent = billboard

    ESP.Data[p] = {highlight = highlight, billboard = billboard, label = label}
    return true
end

local function UpdateESPState()
    for p, data in pairs(ESP.Data) do
        if ESP.Enabled then
            data.highlight.Enabled = ESP.ShowHighlight
            data.billboard.Enabled = true
        else
            data.highlight.Enabled = false
            data.billboard.Enabled = false
        end
    end
end

local function UpdateESPColors()
    local time = tick()
    local color = GetESPColor(time)
    for p, data in pairs(ESP.Data) do
        if data.highlight and data.highlight.Enabled then
            data.highlight.FillColor = color
            data.highlight.OutlineColor = color
        end
        if data.label then
            data.label.TextColor3 = color
        end
    end
end

local function UpdateESPInfo()
    for p, data in pairs(ESP.Data) do
        if data.label and p.Parent then
            data.label.Text = GetDisplayName(p) .. GetTotalKills(p)
        end
    end
end

local function RefreshESP()
    for p, data in pairs(ESP.Data) do
        if not p.Parent or not p.Character then
            data.highlight:Destroy()
            data.billboard:Destroy()
            ESP.Data[p] = nil
        end
    end
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and not ESP.Data[p] then
            CreateESPForPlayer(p)
        end
    end
    UpdateESPState()
end

Players.PlayerAdded:Connect(function(p)
    if p == LocalPlayer then return end
    p.CharacterAdded:Connect(function()
        task.wait(0.5)
        if ESP.Data[p] then
            ESP.Data[p].highlight:Destroy()
            ESP.Data[p].billboard:Destroy()
            ESP.Data[p] = nil
        end
        CreateESPForPlayer(p)
        UpdateESPState()
        UpdateESPColors()
    end)
    task.wait(0.5)
    CreateESPForPlayer(p)
    UpdateESPState()
    UpdateESPColors()
end)

Players.PlayerRemoving:Connect(function(p)
    if ESP.Data[p] then
        ESP.Data[p].highlight:Destroy()
        ESP.Data[p].billboard:Destroy()
        ESP.Data[p] = nil
    end
end)

for _, p in pairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then
        p.CharacterAdded:Connect(function()
            task.wait(0.5)
            if ESP.Data[p] then
                ESP.Data[p].highlight:Destroy()
                ESP.Data[p].billboard:Destroy()
                ESP.Data[p] = nil
            end
            CreateESPForPlayer(p)
            UpdateESPState()
            UpdateESPColors()
        end)
    end
end

RunService.Heartbeat:Connect(function()
    if ESP.Enabled then
        UpdateESPColors()
        if tick() % 0.5 < 0.05 then
            UpdateESPInfo()
        end
    end
end)

