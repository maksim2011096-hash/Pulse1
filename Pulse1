-- === АНИМАЦИЯ ПРИ ВКЛЮЧЕНИИ ФУНКЦИИ ===
local function animateButton(btn, active)
    if active then
        local tween = TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundColor3 = Color3.fromRGB(0, 100, 50),
            BorderColor3 = Color3.fromRGB(0, 255, 100)
        })
        tween:Play()
    else
        local tween = TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundColor3 = Color3.fromRGB(40, 20, 60),
            BorderColor3 = Color3.fromRGB(200, 100, 255)
        })
        tween:Play()
    end
end

