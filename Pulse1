local universalButtons = {}
local function createStyledButton(text, y, icon, url)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 34)
    btn.Position = UDim2.new(0.05, 0, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(140, 80, 220)
    btn.BackgroundTransparency = 0.05
    btn.BorderSizePixel = 1
    btn.BorderColor3 = Color3.fromRGB(220, 180, 255)
    btn.Text = "  " .. icon .. "  " .. text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 13
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.Parent = universalContent
    
    local grad = Instance.new("UIGradient")
    grad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(160, 100, 240)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 140, 255))
    })
    grad.Rotation = 45
    grad.Parent = btn
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 10)
    btnCorner.Parent = btn
    
    local shadow = Instance.new("UIStroke")
    shadow.Color = Color3.fromRGB(220, 180, 255)
    shadow.Thickness = 0
    shadow.Transparency = 0.5
    shadow.Parent = btn
    
    table.insert(universalButtons, btn)
    
    local enterTween, leaveTween
    btn.MouseEnter:Connect(function()
        if enterTween then enterTween:Cancel() end
        enterTween = TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundTransparency = 0,
            Size = UDim2.new(0.92, 0, 0, 36),
            BorderSizePixel = 2
        })
        enterTween:Play()
        shadow.Thickness = 2
        shadow.Transparency = 0.2
    end)
    
    btn.MouseLeave:Connect(function()
        if leaveTween then leaveTween:Cancel() end
        leaveTween = TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundTransparency = 0.05,
            Size = UDim2.new(0.9, 0, 0, 34),
            BorderSizePixel = 1
        })
        leaveTween:Play()
        shadow.Thickness = 0
        shadow.Transparency = 0.5
    end)
    
    local active = false
    btn.MouseButton1Click:Connect(function()
        active = not active
        if active then
            local tween = TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                BackgroundColor3 = Color3.fromRGB(0, 180, 100),
                BorderColor3 = Color3.fromRGB(0, 255, 150)
            })
            tween:Play()
            btn.Text = "● " .. icon .. " " .. text
            if url then
                print("🔄 Загрузка " .. text)
                pcall(function()
                    loadstring(game:HttpGet(url))()
                end)
            end
        else
            local tween = TweenService:Create(btn, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                BackgroundColor3 = Color3.fromRGB(140, 80, 220),
                BorderColor3 = Color3.fromRGB(220, 180, 255)
            })
            tween:Play()
            btn.Text = "  " .. icon .. "  " .. text
        end
    end)
end

