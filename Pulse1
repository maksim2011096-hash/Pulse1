    inputBox.ZIndex = 21
    inputBox.ClearTextOnFocus = false
    
    local inputCorner = Instance.new("UICorner")
    inputCorner.CornerRadius = UDim.new(0, 10)
    inputCorner.Parent = inputBox
    
    -- Кнопка подтверждения
    local confirmBtn = Instance.new("TextButton")
    confirmBtn.Size = UDim2.new(0.3, 0, 0, 40)
    confirmBtn.Position = UDim2.new(0.35, 0, 0, 105)
    confirmBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 255)
    confirmBtn.BackgroundTransparency = 0.2
    confirmBtn.BorderSizePixel = 0
    confirmBtn.Text = "▶ ВОЙТИ"
    confirmBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    confirmBtn.Font = Enum.Font.GothamBold
    confirmBtn.TextSize = 16
    confirmBtn.Parent = mainFrame
    confirmBtn.ZIndex = 21
    
    local btnCorner = Instance.new("UICorner")
    btnCorner.CornerRadius = UDim.new(0, 10)
    btnCorner.Parent = confirmBtn
    
    -- Результат
    local resultLabel = Instance.new("TextLabel")
    resultLabel.Size = UDim2.new(1, 0, 0, 30)
    resultLabel.Position = UDim2.new(0, 0, 0, 155)
    resultLabel.BackgroundTransparency = 1
    resultLabel.Text = ""
    resultLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    resultLabel.Font = Enum.Font.Gotham
    resultLabel.TextSize = 14
    resultLabel.Parent = mainFrame
    resultLabel.ZIndex = 21
    
    -- Переменная для результата
    local success = false
    
    -- Функция проверки
    local function checkInput()
        local entered = inputBox.Text:lower():gsub(" ", "")
        if entered == correctCode then
            success = true
            resultLabel.Text = "✅ ДОСТУП РАЗРЕШЕН!"
            resultLabel.TextColor3 = Color3.fromRGB(0, 255, 150)
            codeGui:Destroy()
            return true
        else
            resultLabel.Text = "❌ НЕВЕРНЫЙ КОД! Попробуйте снова."
            resultLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            inputBox.Text = ""
            return false
        end
    end
    
    confirmBtn.MouseButton1Click:Connect(checkInput)
    inputBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            checkInput()
        end
    end)
    
    -- Закрытие по Enter
    UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.Return and codeGui and codeGui.Parent then
            checkInput()
        end
    end)
    
    -- Замораживаем выполнение пока не введут код
    while codeGui and codeGui.Parent do
        task.wait(0.1)
        if success then break end
    end
    
    return success
end

